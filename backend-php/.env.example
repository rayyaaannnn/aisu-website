# ═══════════════════════════════════════════════════════════════
#  AISU Backend — Environment Configuration
#  Copy this file to .env in this directory and fill in values.
# ═══════════════════════════════════════════════════════════════

# JWT Secret (REQUIRED — generate a strong random string)
JWT_SECRET_KEY=your-64-char-random-hex-string-here

# SMTP / Email (REQUIRED for member notifications, password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Razorpay Payment Gateway (REQUIRED for membership payments)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Twilio SMS (optional — only needed if using SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# Quiz WebSocket Server (for live quiz rooms)
# NOTE: This value is for reference only. The quiz socket URL is configured on the
# frontend. In production, open browser console and run:
#   localStorage.setItem('aisu_socket_url', 'wss://your-quiz-server.com')
# QUIZ_SOCKET_URL=http://localhost:3001
