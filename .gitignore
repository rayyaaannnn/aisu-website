backend-php/uploads/gallery/*

# Maintain empty directories in git
!backend-php/uploads/**/.gitkeep
!backend-php/data/.gitkeep

# Sensitive config (contains SMTP credentials)
backend-php/config.php

# PHPMailer vendor
backend-php/vendor/
backend-php/composer.lock

# Logs and OS files
*.log
.DS_Store
Thumbs.db
