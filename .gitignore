# Node.js
node_modules/
npm-debug.log
yarn-error.log

# PHP backend data & uploads (do not commit user data)
backend-php/data/*.json
backend-php/uploads/govtid/*
backend-php/uploads/payment/*
backend-php/uploads/photo/*
backend-php/uploads/sign/*
backend-php/uploads/complaint/*
backend-php/uploads/cert_templates/*
