# ═══════════════════════════════════════════════════════════════
#  AISU Website — .gitignore (Production Ready)
# ═══════════════════════════════════════════════════════════════

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log

# ── PHP Backend ───────────────────────────────────────────────
backend-php/vendor/
backend-php/composer.lock

# ── Environment & Config (Sensitive) ─────────────────────────
backend-php/.env
.env

# ── SQLite Database (contains real user data) ────────────────
backend-php/data/aisu.sqlite
backend-php/data/*.json

# ── User Uploads (do not commit user data) ───────────────────
backend-php/uploads/govtid/*
backend-php/uploads/payment/*
backend-php/uploads/photo/*
backend-php/uploads/sign/*
backend-php/uploads/complaint/*
backend-php/uploads/cert_templates/*
backend-php/uploads/certificates/*
backend-php/uploads/resume/*
backend-php/uploads/submissions/*
backend-php/uploads/innovations/*
backend-php/uploads/press/*
backend-php/uploads/gallery/*

# Maintain empty directories in git
!backend-php/uploads/**/.gitkeep
!backend-php/data/.gitkeep

# ── Logs & OS Files ──────────────────────────────────────────
*.log
php-server.log
quiz-server.log
.DS_Store
Thumbs.db

# ── Temporary / Dev Files ────────────────────────────────────
nul
TurboVPN_setup.exe
php.phar

# ── IDE / Editor ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS Temporary ─────────────────────────────────────────────
# Windows shortcuts
*.lnk
# macOS attributes
.DS_Store?
